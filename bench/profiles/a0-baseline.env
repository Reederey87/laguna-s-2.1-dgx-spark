# A0 — baseline: model card's DGX Spark recipe, verbatim. VERDICT: reference.
# All serve.sh defaults with MAX_NUM_BATCHED_TOKENS=none: max-num-seqs 32,
# no max-num-batched-tokens (engine falls to 2048 on GB10 ->
# max_num_scheduled_tokens 1600 under DFlash, and warns about it),
# no attention-backend (auto=FlashInfer), no top_k in gen override
# (checkpoint generation_config.json already supplies top_k=20).
MAX_NUM_BATCHED_TOKENS=none
